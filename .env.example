# ── Ports ─────────────────────────────────────────────────────────────────────
# Change these if the defaults conflict with other services on your host.
# Development only:
BACKEND_PORT=8000   # Host port for the FastAPI backend (mapped to container port 8000)
FRONTEND_PORT=5173  # Host port for the Vite dev server  (mapped to container port 5173)
# Production only:
HTTP_PORT=80        # Host port for the Nginx frontend    (mapped to container port 80)

# ── Application ───────────────────────────────────────────────────────────────
APP_URL=https://questboard.yourdomain.com

# Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-openssl-rand-hex-32

# Leave blank to allow open registration. If set, new users must supply this
# code during the OIDC callback before their account is created.
INVITE_CODE=

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=questboard
POSTGRES_USER=questboard
POSTGRES_PASSWORD=changeme

POSTGRES_MIGRATE_USER=questboard_migrate
POSTGRES_MIGRATE_PASSWORD=changeme_migrate

# Async URL used by the FastAPI application
DATABASE_URL=postgresql+asyncpg://questboard:changeme@db:5432/questboard

# URL used by Alembic migrations (runs as the privileged migrate user).
# Must use postgresql+asyncpg:// — the container has asyncpg only, not psycopg2.
DATABASE_MIGRATE_URL=postgresql+asyncpg://questboard_migrate:changeme_migrate@db:5432/questboard

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── OIDC (generic — works with Authentik, Keycloak, Google, etc.) ─────────────
# Authentik example:
#   OIDC_DISCOVERY_URL=https://auth.yourdomain.com/application/o/questboard/.well-known/openid-configuration
# Keycloak example:
#   OIDC_DISCOVERY_URL=https://auth.yourdomain.com/realms/myrealm/.well-known/openid-configuration
OIDC_DISCOVERY_URL=https://auth.yourdomain.com/application/o/questboard/.well-known/openid-configuration
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=https://questboard.yourdomain.com/auth/callback

# ── Notifications ──────────────────────────────────────────────────────────────
# Optional fallback webhook used when a campaign has no webhook configured.
# Leave blank to disable global notifications.
DEFAULT_DISCORD_WEBHOOK_URL=

# ── Celery ─────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
